msgid "Favorites"
msgstr "ລາຍການທີ່ມັກ"

#: src/appfinder-preferences.c:315 src/appfinder-preferences.c:336
msgid "C_lear"
msgstr "_ລ້າງ"

#: src/appfinder-preferences.c:316
msgid "This will permanently clear the custom command history."
msgstr "ນີ້ຈະລ້າງປະຫວັດຄຳສັ່ງທີ່ກຳນົດເອງແບບຖາວອນ."

#: src/appfinder-preferences.c:317
msgid "Are you sure you want to clear the command history?"
msgstr "ເຈົ້າແນ່ໃຈບໍ່ວ່າຕ້ອງການລ້າງປະຫວັດຄຳສັ່ງ?"

#: src/appfinder-preferences.c:337
msgid "This will permanently clear the recent items history."
msgstr "ນີ້ຈະລ້າງປະຫວັດລາຍການທີ່ໃຊ້ຫວ່າງໆນີ້ແບບຖາວອນ."

#: src/appfinder-preferences.c:338
msgid "Are you sure you want to clear the recent items history?"
msgstr "ເຈົ້າແນ່ໃຈບໍ່ວ່າຕ້ອງການລ້າງປະຫວັດລາຍການທີ່ໃຊ້ຫວ່າງໆນີ້?"

#: src/appfinder-preferences.c:450
msgid "_Delete"
msgstr "_ລຶບ"

#: src/appfinder-preferences.c:451
msgid "The custom action will be deleted permanently."
msgstr "ການກະທຳທີ່ກຳນົດເອງຈະຖືກລຶບແບບຖາວອນ."

#: src/appfinder-preferences.c:452
#, c-format
msgid "Are you sure you want to delete action \"%s\"?"
msgstr "ເຈົ້າແນ່ໃຈບໍ່ວ່າຕ້ອງການລຶບການກະທຳ \"%s\"?"

#: src/appfinder-window.c:247 src/appfinder-preferences.glade:81
#: data/xfce4-appfinder.desktop.in:10
#: data/org.xfce.xfce4-appfinder.appdata.xml.in:8
msgid "Application Finder"
msgstr "ຕົວຄົ້ນຫາແອັບພລິເຄຊັນ"

#: src/appfinder-window.c:300
msgid "Toggle view mode"
msgstr "ສະຫຼັບໂໝດການເບິ່ງ"

#: src/appfinder-window.c:381
msgid "_Preferences"
msgstr "_ການຕັ້ງຄ່າ"

#: src/appfinder-window.c:392 src/appfinder-window.c:1287
msgid "La_unch"
msgstr "ເ_ລີ່ມໃຊ້"

#: src/appfinder-window.c:1025
msgid "Failed to launch desktop item editor"
msgstr "ບໍ່ສາມາດເປີດຕົວແກ້ໄຂລາຍການເດັສທັອບໄດ້"

#: src/appfinder-window.c:1050
msgid "Confirm"
msgstr "ຢືນຢັນ"

#: src/appfinder-window.c:1051
msgid ""
"This will permanently remove the custom desktop file from your home "
"directory."
msgstr "ນີ້ຈະລຶບໄຟລ໌ເດັສທັອບທີ່ກຳນົດເອງອອກຈາກໂຟນເດີຫຼັກຂອງທ່ານແບບຖາວອນ."

#: src/appfinder-window.c:1052
#, c-format
msgid "Are you sure you want to revert \"%s\"?"
msgstr "ເຈົ້າແນ່ໃຈບໍ່ວ່າຕ້ອງການຄືນຄ່າ \"%s\"?"

#: src/appfinder-window.c:1062
msgid "Failed to remove desktop file"
msgstr "ບໍ່ສາມາດລຶບໄຟລ໌ເດັສທັອບໄດ້"

#. I18N: the first %s will be replace with users' applications directory, the
#. * second with Hidden=true
#: src/appfinder-window.c:1095
#, c-format
msgid ""
"To unhide the item you have to manually remove the desktop file from \"%s\" "
"or open the file in the same directory and remove the line \"%s\"."
msgstr "ເພື່ອສະແດງລາຍການທີ່ຊ່ອນໄວ້ ເຈົ້າຕ້ອງລຶບໄຟລ໌ເດັສທັອບອອກຈາກ \"%s\" ດ້ວຍຕົນເອງ ຫຼື ເປີດໄຟລ໌ໃນໂຟນເດີດຽວກັນແລ້ວລຶບແຖວ \"%s\" ອອກ."

#: src/appfinder-window.c:1100 src/appfinder-window.c:1333
msgid "_Hide"
msgstr "_ຊ່ອນ"

#: src/appfinder-window.c:1101
#, c-format
msgid "Are you sure you want to hide \"%s\"?"
msgstr "ເຈົ້າແນ່ໃຈບໍ່ວ່າຕ້ອງການຊ່ອນ \"%s\"?"

#: src/appfinder-window.c:1269
msgid "Remove From Favorites"
msgstr "ລຶບອອກຈາກລາຍການທີ່ມັກ"

#: src/appfinder-window.c:1269
msgid "Add to Favorites"
msgstr "ເພີ່ມເຂົ້າໃນລາຍການທີ່ມັກ"

#: src/appfinder-window.c:1301
msgid "_Edit"
msgstr "_ແກ້ໄຂ"

#: src/appfinder-window.c:1318
msgid "_Revert"
msgstr "_ຄືນຄ່າ"

#: src/main.c:65
msgid "Start in collapsed mode"
msgstr "ເລີ່ມໃນໂໝດຫຍໍ້"

#: src/main.c:66
msgid "Print version information and exit"
msgstr "ພິມຂໍ້ມູນເວີຊັນ ແລະ ອອກ"

#: src/main.c:67
msgid "Replace the existing service"
msgstr "ແທນທີ່ການບໍລິການທີ່ມີຢູ່"

#: src/main.c:68
msgid "Quit all instances"
msgstr "ອອກຈາກທຸກອິນສະແຕນຊ໌"

#: src/main.c:69
msgid "Do not try to use or become a D-Bus service"
msgstr "ບໍ່ຕ້ອງພະຍາຍາມໃຊ້ ຫຼື ກາຍເປັນບໍລິການ D-Bus"

#: src/main.c:70
msgid "Toggle window visibility of background service"
msgstr "ສະຫຼັບການເບິ່ງເຫັນໜ້າຕ່າງຂອງບໍລິການພື້ນຫຼັງ"

#: src/main.c:71
msgid "Run in daemon mode"
msgstr "ເຮັດວຽກໃນໂໝດດີມອນ (daemon)"

#: src/main.c:243
#, c-format
msgid "Type \"%s --help\" for usage."
msgstr "ພິມ \"%s --help\" ເພື່ອເບິ່ງວິທີໃຊ້."

#: src/main.c:254
msgid "The Xfce development team. All rights reserved."
msgstr "ທີມງານພັດທະນາ Xfce. ສະຫງວນລິຂະສິດທັງໝົດ."

#: src/main.c:255
#, c-format
msgid "Please report bugs to <%s>."
msgstr "ກະລຸນາລາຍງານຂໍ້ຜິດພາດໄປທີ່ <%s>."

#: src/appfinder-preferences.glade:13
msgid "Prefix"
msgstr "ຄຳນຳໜ້າ"

#: src/appfinder-preferences.glade:16
msgid "Regular Expression"
msgstr "ເຣກູລາເອກເພຣດຊັນ (Regular Expression)"

#: src/appfinder-preferences.glade:37
msgid "Very Small"
msgstr "ນ້ອຍຫຼາຍ"

#: src/appfinder-preferences.glade:40
msgid "Smaller"
msgstr "ນ້ອຍລົງ"

#: src/appfinder-preferences.glade:43
msgid "Small"
msgstr "ນ້ອຍ"

#: src/appfinder-preferences.glade:46
msgid "Normal"
msgstr "ປົກກະຕິ"

#: src/appfinder-preferences.glade:49
msgid "Large"
msgstr "ໃຫຍ່"

#: src/appfinder-preferences.glade:52
msgid "Larger"
msgstr "ໃຫຍ່ຂຶ້ນ"

#: src/appfinder-preferences.glade:55
msgid "Very Large"
msgstr "ໃຫຍ່ຫຼາຍ"

#: src/appfinder-preferences.glade:98
msgid "_Close"
msgstr "_ປິດ"

#: src/appfinder-preferences.glade:114
msgid "_Help"
msgstr "_ຊ່ວຍເຫຼືອ"

#: src/appfinder-preferences.glade:167
msgid "Remember last _selected category"
msgstr "ຈື່ໝວດໝູ່ທີ່ເລືອກ _ຫຼ້າສຸດ"

#: src/appfinder-preferences.glade:183
msgid "Always c_enter the window"
msgstr "ໃຫ້ໜ້າຕ່າງຢູ່ _ກາງ ສະເໝີ"

#: src/appfinder-preferences.glade:188
msgid "Center the window on startup."
msgstr "ໃຫ້ໜ້າຕ່າງຢູ່ກາງຕອນເລີ່ມຕົ້ນ."

#: src/appfinder-preferences.glade:201
msgid "Close window when _focus is lost"
msgstr "ປິດໜ້າຕ່າງເມື່ອບໍ່ໄດ້ _ໂຟກັດ"

#: src/appfinder-preferences.glade:206
msgid "When the focus is lost to another window, appfinder should be closed."
msgstr "ເມື່ອໂຟກັດໄປຫາໜ້າຕ່າງອື່ນ, ຕົວຄົ້ນຫາແອັບຄວນຈະຖືກປິດ."

#: src/appfinder-preferences.glade:219
msgid "Keep running _instance in the background"
msgstr "ໃຫ້ _ອິນສະແຕນຊ໌ ເຮັດວຽກຢູ່ພື້ນຫຼັງຕໍ່ໄປ"

#: src/appfinder-preferences.glade:224
msgid ""
"Instead of quitting the application when the last window is closed, keep a "
"running instance to speed up opening new windows. You might want to disable "
"this to reduce memory usage."
msgstr "ແທນທີ່ຈະປິດແອັບພລິເຄຊັນເມື່ອໜ້າຕ່າງສຸດທ້າຍຖືກປິດ, ໃຫ້ຮັກສາອິນສະແຕນຊ໌ທີ່ເຮັດວຽກຢູ່ເພື່ອເລັ່ງການເປີດໜ້າຕ່າງໃໝ່. ເຈົ້າອາດຈະຕ້ອງການປິດການໃຊ້ງານນີ້ເພື່ອຫຼຸດຜ່ອນການໃຊ້ຄວາມຈຳ."

#: src/appfinder-preferences.glade:237
msgid "Single window"
msgstr "ໜ້າຕ່າງດຽວ"

#: src/appfinder-preferences.glade:242
msgid ""
"When an instance is running in the background, only open one window at a "
"time."
msgstr "ເມື່ອມີອິນສະແຕນຊ໌ເຮັດວຽກຢູ່ພື້ນຫຼັງ, ໃຫ້ເປີດພຽງໜ້າຕ່າງດຽວໃນແຕ່ລະຄັ້ງ."

#: src/appfinder-preferences.glade:255
msgid "Sort recently used items first"
msgstr "ຈັດລຽງລາຍການທີ່ໃຊ້ຫວ່າງໆນີ້ຂຶ້ນກ່ອນ"

#: src/appfinder-preferences.glade:260
msgid ""
"Order items, such that items that are most recently used are always on the "
"top."
msgstr "ຈັດລຽງລາຍການ ໂດຍໃຫ້ລາຍການທີ່ໃຊ້ຫຼ້າສຸດຢູ່ທາງເທິງສະເໝີ."

#: src/appfinder-preferences.glade:272
msgid "Single-click selects and launches items"
msgstr "ຄລິກບາດດຽວເພື່ອເລືອກ ແລະ ເປີດລາຍການ"

#: src/appfinder-preferences.glade:277
msgid "Items are selected and launched with only a single-click."
msgstr "ລາຍການຈະຖືກເລືອກ ແລະ ເປີດດ້ວຍການຄລິກພຽງບາດດຽວ."

#: src/appfinder-preferences.glade:295
msgid "Behaviour"
msgstr "ພຶດຕິກຳ"

#: src/appfinder-preferences.glade:330
msgid "_View items as icons"
msgstr "_ເບິ່ງລາຍການເປັນໄອຄອນ"

#: src/appfinder-preferences.glade:345
msgid "Text besi_de icons"
msgstr "ຂໍ້ຄວາມຢູ່ _ຂ້າງ ໄອຄອນ"

#: src/appfinder-preferences.glade:363
msgid "Ite_m icon size:"
msgstr "ຂະໜາດໄອຄອນ _ລາຍການ:"

#: src/appfinder-preferences.glade:377
msgid "Hide category pane"
msgstr "ຊ່ອນແຖບໝວດໝູ່"

#: src/appfinder-preferences.glade:382
msgid "Hide category panel and show all applications."
msgstr "ຊ່ອນແຖບໝວດໝູ່ ແລະ ສະແດງທຸກແອັບພລິເຄຊັນ."

#: src/appfinder-preferences.glade:399
msgid "Categ_ory icon size:"
msgstr "ຂະໜາດໄອຄອນ _ໝວດໝູ່:"

#: src/appfinder-preferences.glade:453
msgid "Hide window decorations"
msgstr "ຊ່ອນສ່ວນຕົກແຕ່ງໜ້າຕ່າງ"

#: src/appfinder-preferences.glade:458
msgid "Hide window decorations such as title bar and borders."
msgstr "ຊ່ອນສ່ວນຕົກແຕ່ງໜ້າຕ່າງ ເຊັ່ນ: ແຖບຊື່ ແລະ ຂອບ."

#: src/appfinder-preferences.glade:473
msgid "Show generic application _names"
msgstr "ສະແດງ _ຊື່ ທົ່ວໄປຂອງແອັບພລິເຄຊັນ"

#: src/appfinder-preferences.glade:497
msgid "Appearance"
msgstr "ຮູບລັກສະນະ"

#: src/appfinder-preferences.glade:527
msgid "C_lear Custom Command History"
msgstr "_ລ້າງ ປະຫວັດຄຳັ່ງທີ່ກຳນົດເອງ"

#: src/appfinder-preferences.glade:539
msgid "Clear _Recently Used Items History"
msgstr "ລ້າງປະຫວັດລາຍການທີ່ໃຊ້ _ຫວ່າງໆນີ້"

#: src/appfinder-preferences.glade:555
msgid "History"
msgstr "ປະຫວັດ"

#: src/appfinder-preferences.glade:574
msgid "_General"
msgstr "_ທົ່ວໄປ"

#: src/appfinder-preferences.glade:598
msgid "Custom actions are only available in collapsed mode."
msgstr "ການກະທຳທີ່ກຳນົດເອງສາມາດໃຊ້ໄດ້ໃນໂໝດຫຍໍ້ເທົ່ານັ້ນ."

#: src/appfinder-preferences.glade:659
msgid "Pattern"
msgstr "ຮູບແບບ"

#: src/appfinder-preferences.glade:695
msgid "Add a new custom action."
msgstr "ເພີ່ມການກະທຳທີ່ກຳນົດເອງໃໝ່."

#: src/appfinder-preferences.glade:716
msgid "Remove the currently selected action."
msgstr "ລຶບການກະທຳທີ່ເລືອກໄວ້ໃນປັດຈຸບັນ."

#: src/appfinder-preferences.glade:774
#, c-format
msgid ""
"If the type is set to prefix, %s will be replaced with the string after the "
"pattern, %S with the complete entry text. For regular expressions you can "
"use \\0 and \\<num>."
